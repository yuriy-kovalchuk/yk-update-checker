#!/usr/bin/env bash
MSG=$(cat "$1")
PATTERN='^(feat|fix|refactor|test|docs|build|ci|chore|perf|style)(!)?:\ .+'

if ! echo "$MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "  Invalid commit message: \"$MSG\""
  echo "  Expected: type: description"
  echo "  Types: feat fix refactor test docs build ci chore perf style"
  echo "  Breaking: feat!: description"
  echo ""
  exit 1
fi
